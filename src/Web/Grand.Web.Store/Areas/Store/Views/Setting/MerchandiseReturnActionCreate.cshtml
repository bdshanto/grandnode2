@model MerchandiseReturnActionModel
@{
    ViewBag.Title = Loc["Admin.Settings.Order.MerchandiseReturnActions.AddNew"];
}
<form asp-area="@Constants.AreaStore" asp-controller="Setting" asp-action="MerchandiseReturnActionCreate" method="post">
    <div class="row">
        <div class="col-md-12">
            <div class="x_panel light form-fit">
                <div class="x_title">
                    <div class="caption">
                        <i class="fa fa-list-alt"></i>
                        @Loc["Admin.Settings.Order.MerchandiseReturnActions.AddNew"]
                        <small>
                            <i class="fa fa-arrow-circle-left"></i>
                            <a href="@Url.Action("Sales", "Setting", new { area = Constants.AreaStore })">@Loc["Admin.Settings.Order.MerchandiseReturnActions.BackToList"]</a>
                        </small>
                    </div>
                    <div class="actions">
                        <button class="btn btn-success" type="submit" name="save">
                            <i class="fa fa-check"></i> @Loc["Admin.Common.Save"]
                        </button>
                        <button class="btn btn-success" type="submit" name="save-continue">
                            <i class="fa fa-check-circle"></i> @Loc["Admin.Common.SaveContinue"]
                        </button>
                    </div>
                </div>
                <div class="x_content form">
                    <partial name="Partials/CreateOrUpdate.MerchandiseReturnAction" model="Model"/>
                </div>
            </div>
        </div>
    </div>
</form>
