@model SalesSettingsModel
@{
    ViewBag.Title = Loc["Admin.Settings.Sales"];
}
<form asp-area="@Constants.AreaStore" asp-controller="Setting" asp-action="Sales" method="post">
    <div asp-validation-summary="All"></div>
    <div class="row">
        <div class="col-md-12">
            <div class="x_panel light form-fit">
                <div class="x_title">
                    <div class="caption">
                        <i class="fa fa-fw fa-sliders"></i>
                        @Loc["Admin.Settings.Sales"]
                    </div>
                    <div class="actions">
                        <div class="btn-group btn-group-devided">
                            <button class="btn btn-success" type="submit" name="save">
                                <i class="fa fa-check"></i> @Loc["Admin.Common.Save"]
                            </button>
                        </div>
                    </div>
                </div>
                <div class="x_content form">
                    <admin-tabstrip name="salessettings-edit">
                        <items>
                            <tabstrip-item text="@Loc["Admin.Settings.Order"]" tab-index="0">
                                <content>
                                    <div>
                                        <partial name="Partials/Sales.TabOrderSettings" model="Model"/>
                                    </div>
                                </content>
                            </tabstrip-item>
                            <tabstrip-item text="@Loc["Admin.Settings.Order.MerchandiseReturnSettings"]" tab-index="1">
                                <content>
                                    <div>
                                        <partial name="Partials/Sales.TabMerchandiseReturn" model="Model"/>
                                    </div>
                                </content>
                            </tabstrip-item>
                            <tabstrip-item text="@Loc["Admin.Settings.ShoppingCart"]" tab-index="2">
                                <content>
                                    <div>
                                        <partial name="Partials/Sales.TabShoppingCart" model="Model"/>
                                    </div>
                                </content>
                            </tabstrip-item>
                            <tabstrip-item text="@Loc["Admin.Settings.LoyaltyPoints"]" tab-index="3">
                                <content>
                                    <div>
                                        <partial name="Partials/Sales.TabLoyaltyPoints" model="Model"/>
                                    </div>
                                </content>
                            </tabstrip-item>
                        </items>
                    </admin-tabstrip>
                </div>
            </div>
        </div>
    </div>
</form>
